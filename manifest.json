{
  "manifest_version": 3,
  "name": "Shopify Detector",
  "version": "1.0.0",
  "description": "Detects if a website is built with Shopify and displays a banner notification.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "/icons/logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}
